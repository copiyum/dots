      "Background Color": $(rgb_float_json "$TERM_BG"),
      "Foreground Color": $(rgb_float_json "$TERM_FG"),
      "Cursor Color": $(rgb_float_json "$TERM_CURSOR"),
      "Selection Color": $(rgb_float_json "$TERM_SELECTION_BG"),
      "Selected Text Color": $(rgb_float_json "$TERM_SELECTION_FG"),
      "Ansi 0 Color": $(rgb_float_json "$ANSI_0"),
      "Ansi 1 Color": $(rgb_float_json "$ANSI_1"),
      "Ansi 2 Color": $(rgb_float_json "$ANSI_2"),
      "Ansi 3 Color": $(rgb_float_json "$ANSI_3"),
