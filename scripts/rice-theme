  <main class="desktop">
    <section class="bar" aria-label="macOS rice bar preview">
      <div class="left">
        <span class="seg dark">1&nbsp;󰖟</span>
        <span class="seg">2&nbsp;󱞁&nbsp;&nbsp;󰨞&nbsp;&nbsp;&gt;_</span>
        <span class="seg">3&nbsp;</span>
        <span class="seg">4&nbsp;󰖟</span>
        <span class="seg">5</span>
        <span class="seg">6</span>
        <span class="seg">7</span>
        <span class="seg">8</span>
        <span class="seg">9</span>
        <span class="seg">10</span>
      </div>
      <div class="center">
      </div>
      <div class="right">
        <span class="seg">󰖩</span>
        <span class="seg">󰂯</span>
        <span class="seg">󰃠</span>
        <span class="seg">&nbsp; 42%</span>
        <span class="seg">&nbsp; 93%</span>
        <span class="seg">󰾇&nbsp; H</span>
        <span class="seg dark">&nbsp; 09:41 PM</span>
      </div>
    </section>

    <section class="terminal" aria-label="macOS rice terminal prompt preview">
      <div class="prompt">
        <span class="p-left"></span><span class="p-user"> </span><span class="p-cut-1"></span><span class="p-dir">  ~/rice </span><span class="p-cut-2"></span><span class="p-git">  main ⇡1 </span><span class="p-final"></span>
