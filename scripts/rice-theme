  chmod +x "$rice_dir/scripts/theme-menu.sh"

  cat > "$config" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
source "$CONFIG_DIR/rice/colors.sh"

PLUGIN_DIR="$CONFIG_DIR/rice/plugins"
