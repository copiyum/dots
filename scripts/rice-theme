  if command -v jq >/dev/null 2>&1; then
    jq empty "$profile"
  fi
}

write_omp() {
  local config="$OUT/oh-my-posh/rice-$THEME_ID.omp.json"
  cat > "$config" <<EOF
{
  "\$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "diamond",
          "leading_diamond": "",
          "foreground": "$PROMPT_FG",
          "background": "$PROMPT_LEFT_BG",
          "template": " "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "$PROMPT_FG",
          "background": "$PROMPT_DIR_BG",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_icon": " ~",
            "folder_separator_icon": "/"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "$PROMPT_ACCENT",
          "background": "$PROMPT_GIT_BG",
          "template": "  {{ .HEAD }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }}{{ if gt .Ahead 0 }} ⇡{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ⇣{{ .Behind }}{{ end }} ",
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "$PROMPT_FINAL_FG",
          "template": "{{ if gt .Code 0 }} {{ else }} {{ end }}",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}
EOF
}

write_aerospace() {
  local config="$OUT/aerospace/aerospace.toml"
  cat > "$config" <<EOF
# Generated by macos-rice for $THEME_NAME.
# i3-style AeroSpace bindings adapted for Ghostty, Raycast, and SketchyBar.
config-version = 2

after-startup-command = [
  'exec-and-forget sketchybar',
  'exec-and-forget borders style=round width=5.0 hidpi=on active_color=0xffe1e3e4 inactive_color=0xff494d64'
]

start-at-login = true
auto-reload-config = true
enable-normalization-flatten-containers = false
enable-normalization-opposite-orientation-for-nested-containers = false
accordion-padding = 10
default-root-container-layout = 'tiles'
default-root-container-orientation = 'auto'
on-focused-monitor-changed = ['move-mouse monitor-lazy-center']
automatically-unhide-macos-hidden-apps = false
focus-follows-mouse.enabled = false
persistent-workspaces = []

exec-on-workspace-change = ['/bin/bash', '-c',
  'sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=\$AEROSPACE_FOCUSED_WORKSPACE'
]

[gaps]
inner.horizontal = 15
inner.vertical = 15
outer.left = 15
outer.bottom = 15
outer.top = 12
outer.right = 15

[mode.main.binding]
alt-enter = 'exec-and-forget open -na Ghostty'

alt-j = 'focus --boundaries-action wrap-around-the-workspace left'
alt-k = 'focus --boundaries-action wrap-around-the-workspace down'
alt-l = 'focus --boundaries-action wrap-around-the-workspace up'
alt-semicolon = 'focus --boundaries-action wrap-around-the-workspace right'

alt-shift-j = 'move left'
alt-shift-k = 'move down'
alt-shift-l = 'move up'
alt-shift-semicolon = 'move right'

alt-h = 'layout --root tiles horizontal'
alt-v = 'layout --root tiles vertical'
alt-f = 'fullscreen'

alt-s = 'layout --root v_accordion'
alt-w = 'layout --root h_accordion'
alt-e = 'layout --root tiles horizontal vertical'
alt-shift-space = 'layout floating tiling'

alt-space = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/search.sh"'
alt-tab = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/aerospace-switcher.sh"'
alt-p = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/power.sh"'
alt-t = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/theme-menu.sh"'
alt-c = 'close --quit-if-last-window'
alt-shift-q = 'close'
alt-shift-c = 'reload-config'
alt-g = 'mode geometry'

alt-1 = 'workspace 1'
alt-2 = 'workspace 2'
alt-3 = 'workspace 3'
alt-4 = 'workspace 4'
alt-5 = 'workspace 5'
alt-6 = 'workspace 6'
alt-7 = 'workspace 7'
alt-8 = 'workspace 8'
alt-9 = 'workspace 9'
alt-0 = 'workspace 10'

alt-shift-1 = 'move-node-to-workspace 1'
alt-shift-2 = 'move-node-to-workspace 2'
alt-shift-3 = 'move-node-to-workspace 3'
alt-shift-4 = 'move-node-to-workspace 4'
alt-shift-5 = 'move-node-to-workspace 5'
alt-shift-6 = 'move-node-to-workspace 6'
alt-shift-7 = 'move-node-to-workspace 7'
alt-shift-8 = 'move-node-to-workspace 8'
alt-shift-9 = 'move-node-to-workspace 9'
alt-shift-0 = 'move-node-to-workspace 10'

[mode.geometry.binding]
up = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/geometry.sh up"'
down = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/geometry.sh down"'
left = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/geometry.sh left"'
right = 'exec-and-forget /bin/bash -lc "\$HOME/.config/sketchybar/rice/scripts/geometry.sh right"'
shift-left = 'resize width -50'
shift-down = 'resize height +50'
shift-up = 'resize height -50'
shift-right = 'resize width +50'
b = 'balance-sizes'
enter = 'mode main'
esc = 'mode main'
