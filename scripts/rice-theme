#!/usr/bin/env zsh
set -euo pipefail

ROOT="${0:A:h:h}"
MODE="preview"

usage() {
  cat <<'EOF'
Usage:
  scripts/rice-theme <white|black>
  scripts/rice-theme --apply <white|black>

Default mode is preview: render files under generated/<theme>/ only.
Apply mode writes guarded outputs to live config locations and backs up touched files.
It never edits ~/.zshrc.
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "--apply" ]]; then
  MODE="apply"
  shift
fi

THEME="${1:-}"
if [[ -z "$THEME" ]]; then
  usage
  exit 1
fi

THEME_FILE="$ROOT/themes/$THEME.env"
if [[ ! -f "$THEME_FILE" ]]; then
  print -u2 "Unknown theme: $THEME"
  print -u2 "Available themes: white, black"
  exit 1
fi

source "$THEME_FILE"

OUT="$ROOT/generated/$THEME_ID"
WALLPAPER="$ROOT/$WALLPAPER_REL"
FONT_NAME="JetBrainsMono Nerd Font"
ITERM_FONT_NAME="JetBrainsMonoNFM-Regular"
BACKUP_DIR="$HOME/.backup/macos-rice/$(date +%Y%m%d_%H%M%S)"

rm -rf "$OUT"
mkdir -p "$OUT"/{aerospace,atuin,ghostty/themes,iterm2/DynamicProfiles,oh-my-posh,palette,sketchybar/rice/plugins,sketchybar/rice/scripts,borders,zsh,services,preview}

no_hash() {
  print -- "${1#\#}"
}

argb() {
  print -- "0xff$(no_hash "$1")"
}

clamp_int() {
  local value="$1"
  local min="$2"
  local max="$3"
  (( value < min )) && value="$min"
  (( value > max )) && value="$max"
  print -- "$value"
}

gray_hex() {
  local value
  value="$(clamp_int "$1" 0 255)"
  printf '#%02x%02x%02x' "$value" "$value" "$value"
}

wallpaper_luma() {
  if command -v magick >/dev/null 2>&1 && [[ -f "$WALLPAPER" ]]; then
    magick "$WALLPAPER" -resize 1x1! -format '%[fx:int(255*(0.2126*r+0.7152*g+0.0722*b))]' info: 2>/dev/null || printf '225'
  else
    printf '225'
  fi
}

rgb_float_json() {
  local hex="$(no_hash "$1")"
  local r=$((16#${hex[1,2]}))
  local g=$((16#${hex[3,4]}))
  local b=$((16#${hex[5,6]}))
  printf '{ "Red Component": %.6f, "Green Component": %.6f, "Blue Component": %.6f, "Alpha Component": 1 }' \
    "$(( r / 255.0 ))" "$(( g / 255.0 ))" "$(( b / 255.0 ))"
}

write_palette() {
  local shell_file="$OUT/palette/colors.sh"
  local json_file="$OUT/palette/colors.json"

  cat > "$shell_file" <<EOF
#!/usr/bin/env bash
# Generated by macos-rice for $THEME_NAME.
export RICE_THEME="$THEME_ID"
export RICE_MODE="$THEME_MODE"
export RICE_BACKGROUND="$TERM_BG"
export RICE_FOREGROUND="$TERM_FG"
export RICE_CURSOR="$TERM_CURSOR"
export RICE_ANSI_0="$ANSI_0"
export RICE_ANSI_1="$ANSI_1"
export RICE_ANSI_2="$ANSI_2"
export RICE_ANSI_3="$ANSI_3"
export RICE_ANSI_4="$ANSI_4"
export RICE_ANSI_5="$ANSI_5"
export RICE_ANSI_6="$ANSI_6"
export RICE_ANSI_7="$ANSI_7"
export RICE_ANSI_8="$ANSI_8"
export RICE_ANSI_9="$ANSI_9"
export RICE_ANSI_10="$ANSI_10"
export RICE_ANSI_11="$ANSI_11"
export RICE_ANSI_12="$ANSI_12"
export RICE_ANSI_13="$ANSI_13"
export RICE_ANSI_14="$ANSI_14"
export RICE_ANSI_15="$ANSI_15"
EOF
  chmod +x "$shell_file"

  cat > "$json_file" <<EOF
{
  "theme": "$THEME_ID",
  "mode": "$THEME_MODE",
  "special": {
    "background": "$TERM_BG",
    "foreground": "$TERM_FG",
    "cursor": "$TERM_CURSOR"
  },
  "colors": {
    "color0": "$ANSI_0",
    "color1": "$ANSI_1",
    "color2": "$ANSI_2",
    "color3": "$ANSI_3",
    "color4": "$ANSI_4",
    "color5": "$ANSI_5",
    "color6": "$ANSI_6",
    "color7": "$ANSI_7",
    "color8": "$ANSI_8",
    "color9": "$ANSI_9",
    "color10": "$ANSI_10",
    "color11": "$ANSI_11",
    "color12": "$ANSI_12",
    "color13": "$ANSI_13",
    "color14": "$ANSI_14",
    "color15": "$ANSI_15"
  }
}
EOF
  if command -v jq >/dev/null 2>&1; then
    jq empty "$json_file"
  fi
}

backup_path() {
  local target_path="$1"
  if [[ -e "$target_path" || -L "$target_path" ]]; then
    mkdir -p "$BACKUP_DIR/${target_path:h}"
    cp -R "$target_path" "$BACKUP_DIR/$target_path"
  fi
}

replace_marked_block() {
  local file="$1"
  local block="$2"
  local begin="# BEGIN MACOS RICE"
  local end="# END MACOS RICE"
  mkdir -p "${file:h}"
  if [[ -f "$file" ]]; then
    backup_path "$file"
    awk -v begin="$begin" -v end="$end" '
      $0 == begin { skip = 1; next }
      $0 == end { skip = 0; next }
      skip != 1 { print }
    ' "$file" > "$file.tmp"
    mv "$file.tmp" "$file"
  fi
  {
    print -- "$begin"
    print -- "$block"
    print -- "$end"
  } >> "$file"
}

write_ghostty() {
  local theme_file="$OUT/ghostty/themes/rice-$THEME_ID"
  local config_file="$OUT/ghostty/config.ghostty"
  local legacy_config_file="$OUT/ghostty/config"

  cat > "$theme_file" <<EOF
# Generated by macos-rice for $THEME_NAME.
background = $TERM_BG
foreground = $TERM_FG
cursor-color = $TERM_CURSOR
selection-background = $TERM_SELECTION_BG
selection-foreground = $TERM_SELECTION_FG
palette = 0=$ANSI_0
palette = 1=$ANSI_1
palette = 2=$ANSI_2
palette = 3=$ANSI_3
palette = 4=$ANSI_4
palette = 5=$ANSI_5
palette = 6=$ANSI_6
palette = 7=$ANSI_7
palette = 8=$ANSI_8
palette = 9=$ANSI_9
palette = 10=$ANSI_10
palette = 11=$ANSI_11
palette = 12=$ANSI_12
palette = 13=$ANSI_13
palette = 14=$ANSI_14
palette = 15=$ANSI_15
EOF

  cat > "$config_file" <<EOF
# Preview config. Copy or include this only after review.
font-family = "$FONT_NAME"
font-size = 12
theme = rice-$THEME_ID
cursor-style = block
cursor-style-blink = true
background = $TERM_BG
foreground = $TERM_FG
cursor-color = $TERM_CURSOR
selection-background = $TERM_SELECTION_BG
selection-foreground = $TERM_SELECTION_FG
window-padding-x = 30
window-padding-y = 30
background-opacity = 1
background-blur-radius = 0
macos-titlebar-style = tabs
EOF
  cp "$config_file" "$legacy_config_file"
}

