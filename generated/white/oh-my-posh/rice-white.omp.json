{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "diamond",
          "leading_diamond": "",
          "foreground": "#EFF1F5",
          "background": "#333333",
          "template": " "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#EFF1F5",
          "background": "#474747",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_icon": " ~",
            "folder_separator_icon": "/"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#EFF1F5",
          "background": "#474747",
          "template": "  {{ .HEAD }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }}{{ if gt .Ahead 0 }} ⇡{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ⇣{{ .Behind }}{{ end }} ",
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#474747",
          "template": "{{ if gt .Code 0 }} {{ else }} {{ end }}",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}
